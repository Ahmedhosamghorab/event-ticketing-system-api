# Application
PORT=3000
NODE_ENV=development
APP_NAME="Event Ticketing API"

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=event_ticketing_db
DB_SYNCHRONIZE=true
DB_LOGGING=true
DB_SSL=false
DB_RETRY_ATTEMPTS=10
DB_RETRY_DELAY=3000

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=3600s
