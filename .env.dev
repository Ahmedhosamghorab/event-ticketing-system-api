# Application
PORT=3000
NODE_ENV=dev
APP_NAME="Event Ticketing API (Development)"

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=event_ticketing_dev_db
DB_SYNCHRONIZE=true
DB_LOGGING=true
DB_SSL=false
DB_RETRY_ATTEMPTS=10
DB_RETRY_DELAY=3000

# JWT
JWT_SECRET=dev-secret-key-change-me
JWT_EXPIRES_IN=3600s
