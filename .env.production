# Application
PORT=3000
NODE_ENV=production
APP_NAME="Event Ticketing API"

# Database
DB_HOST=prod-db-host
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=secure-prod-password
DB_DATABASE=event_ticketing_prod_db
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_SSL=true
DB_RETRY_ATTEMPTS=5
DB_RETRY_DELAY=5000

# JWT
JWT_SECRET=production-extremely-long-secure-and-random-key-change-me
JWT_EXPIRES_IN=900s
